# 霞台市公共施設予約管理システム(KSM-DEV-001 §3-5)
# 文字コード UTF-8(REQ-027 整合)・改行 LF
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_size = 2
max_line_length = 120

[*.{ts,tsx,mjs,cjs,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
